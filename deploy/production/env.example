# ============================================================================
# HiveMind Production Environment Variables
# ============================================================================
# Copy to /etc/hivemind/env and fill in values
# ============================================================================

# Signaling server URL for NAT traversal
HIVEMIND_SIGNALING_URL=wss://signal.yourdomain.com

# Redis connection (for multi-instance deployments)
HIVEMIND_REDIS_URL=redis://127.0.0.1:6379/0

# TLS (if terminating at application level)
# HIVEMIND_TLS_CERT=/etc/hivemind/certs/fullchain.pem
# HIVEMIND_TLS_KEY=/etc/hivemind/certs/privkey.pem

# GPU device selection (comma-separated for multi-GPU)
# CUDA_VISIBLE_DEVICES=0

# Worker tuning
HIVEMIND_WORKER_POOL_SIZE=4
HIVEMIND_WORKER_MAX_CONCURRENT=8
